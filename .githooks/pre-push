#!/bin/sh
# Blocks pushing maintainer-only files to the public wittness-tt repo.
blocked_patterns="docs/PUBLISH-ON-GITHUB.md docs/SOCIAL-SHARE.md docs/SECURITY.md docs/README.md"

while read local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue

  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  for path in $(git diff --name-only $range 2>/dev/null); do
    for blocked in $blocked_patterns; do
      if [ "$path" = "$blocked" ]; then
        echo ""
        echo "BLOCKED: $path is maintainer-only and must not be pushed."
        echo "Keep notes in _private/ (gitignored). See .githooks/README"
        echo ""
        exit 1
      fi
    done
    case "$path" in
      _private/*|local/*)
        echo ""
        echo "BLOCKED: $path is in a private folder and must not be pushed."
        echo ""
        exit 1
        ;;
    esac
  done
done

exit 0